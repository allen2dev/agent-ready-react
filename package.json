{
  "name": "agent-ready-react",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate": "turbo run validate",
    "attw": "node scripts/check-exports.mjs",
    "codegen:docs": "pnpm --filter @agent-ready/cli build && node packages/cli/dist/index.js codegen docs docs/api/index.md",
    "bench": "node scripts/bench/run.mjs",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@agent-ready/runtime": "workspace:*",
    "@agent-ready/schema": "workspace:*",
    "@arethetypeswrong/cli": "^0.17.4",
    "@changesets/cli": "^2.27.10",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  }
}
