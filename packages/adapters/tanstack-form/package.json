{
  "name": "@agent-ready/adapter-tanstack-form",
  "version": "0.0.0",
  "publishConfig": { "access": "public" },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "node -e \"process.exit(0)\"",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "@agent-ready/react": "workspace:*",
    "@agent-ready/schema": "workspace:*",
    "@tanstack/react-form": "^0.40.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@agent-ready/react": "workspace:*",
    "@agent-ready/schema": "workspace:*"
  },
  "devDependencies": {
    "@agent-ready/testing": "workspace:*",
    "@agent-ready/tsconfig": "workspace:*",
    "@agent-ready/vitest-config": "workspace:*",
    "@tanstack/react-form": "^0.48.2",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
